# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@rewards.penkey.co.uk
RESEND_REPLY_TO_EMAIL=nfdrepairs@gmail.com

# Admin Configuration
# Comma-separated list of emails that should have admin access
ADMIN_EMAILS=john@penkey.co.uk,amanda@penkey.co.uk

# App Configuration
NEXT_PUBLIC_APP_URL=https://perks.penkey.co.uk
NEXT_PUBLIC_POS_URL=http://localhost:3001
NODE_ENV=production

# Weather API (OpenWeatherMap) - FREE tier
# Sign up at: https://openweathermap.org/api
# Location: Lymington, UK (50.7594, -1.5339)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Cron Job Secret (for scheduled tasks)
# Generate with: openssl rand -base64 32
CRON_SECRET=your_random_cron_secret_here

# Push Notifications (Web Push / VAPID Keys)
# Generate with: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:nfdrepairs@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
